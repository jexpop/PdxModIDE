<UserControl x:Class="PdxModIDE.UI.ProfileTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="{DynamicResource ProfileTab_SelectProfile}" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding Profiles}" 
                      DisplayMemberPath="Name"
                      SelectedItem="{Binding CurrentProfile, Mode=TwoWay}"
                      Margin="0,0,0,10"/>

            <GroupBox Header="{DynamicResource ProfileTab_Routes}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ProfileTab_GameRoot}" Margin="0,5,0,0"/>
                    <DockPanel Margin="0,2,0,5">
                        <Button Content="{DynamicResource ProfileTab_Browse}" Width="80" 
                                Command="{Binding BrowseGameRootCommand}"
                                DockPanel.Dock="Right" Margin="5,0,0,0"/>
                        <TextBox Text="{Binding CurrentProfile.GameRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>

                    <TextBlock Text="{DynamicResource ProfileTab_ModRoot}" Margin="0,5,0,0"/>
                    <DockPanel Margin="0,2,0,5">
                        <Button Content="{DynamicResource ProfileTab_Browse}" Width="80" 
                                Command="{Binding BrowseModRootCommand}"
                                DockPanel.Dock="Right" Margin="5,0,0,0"/>
                        <TextBox Text="{Binding CurrentProfile.ModRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>

                    <TextBlock Text="{DynamicResource ProfileTab_BackupRoot}" Margin="0,5,0,0"/>
                    <DockPanel Margin="0,2,0,5">
                        <Button Content="{DynamicResource ProfileTab_Browse}" Width="80" 
                                Command="{Binding BrowseBackupRootCommand}"
                                DockPanel.Dock="Right" Margin="5,0,0,0"/>
                        <TextBox Text="{Binding CurrentProfile.BackupRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="{DynamicResource ProfileTab_SaveProfile}" Width="120" Margin="0,0,10,0" 
                        Command="{Binding SaveProfileCommand}"/>
                <Button Content="{DynamicResource ProfileTab_NewProfile}" Width="120" Margin="0,0,10,0"
                        Command="{Binding CreateProfileCommand}"/>
                <Button Content="{DynamicResource ProfileTab_RenameProfile}" Width="120" Margin="0,0,10,0"
                        Command="{Binding RenameProfileCommand}"/>
                <Button Content="{DynamicResource ProfileTab_DeleteProfile}" Width="120"
                        Command="{Binding DeleteProfileCommand}"/>
            </StackPanel>


        </StackPanel>
    </ScrollViewer>
</UserControl>
