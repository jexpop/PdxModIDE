<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="#1A120B"/>
    <SolidColorBrush x:Key="WindowForeground" Color="#E8C97E"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#2A1F14"/>
    <SolidColorBrush x:Key="ControlForeground" Color="#E8C97E"/>
    <SolidColorBrush x:Key="ControlBorder" Color="#6B4F2E"/>
    <SolidColorBrush x:Key="AccentColor" Color="#D4A84B"/>
    <SolidColorBrush x:Key="AccentForeground" Color="#1A120B"/>
    <SolidColorBrush x:Key="SelectionBackground" Color="#6B4F2E"/>
    <SolidColorBrush x:Key="SelectionForeground" Color="#FFE4A0"/>
    <SolidColorBrush x:Key="ButtonBackground" Color="#3A2A1A"/>
    <SolidColorBrush x:Key="ButtonForeground" Color="#C8A96E"/>
    <SolidColorBrush x:Key="ButtonHoverBackground" Color="#4A3A2A"/>
    <SolidColorBrush x:Key="TextBoxBackground" Color="#1A120B"/>
    <SolidColorBrush x:Key="TextBoxForeground" Color="#E8C97E"/>
    <SolidColorBrush x:Key="ListViewBackground" Color="#1A120B"/>
    <SolidColorBrush x:Key="ListViewForeground" Color="#E8C97E"/>
    <SolidColorBrush x:Key="TreeViewBackground" Color="#1A120B"/>
    <SolidColorBrush x:Key="TreeViewForeground" Color="#E8C97E"/>
    <SolidColorBrush x:Key="TabHeaderBackground" Color="#2A1F14"/>
    <SolidColorBrush x:Key="TabHeaderForeground" Color="#C8A96E"/>
    <SolidColorBrush x:Key="TabSelectedBackground" Color="#1A120B"/>
    <SolidColorBrush x:Key="RichTextBoxBackground" Color="#1A120B"/>
    <SolidColorBrush x:Key="RichTextBoxForeground" Color="#E8C97E"/>
    <SolidColorBrush x:Key="DiffAddedBackground" Color="#2A3A1A"/>
    <SolidColorBrush x:Key="DiffRemovedBackground" Color="#3A1A1A"/>
    <SolidColorBrush x:Key="HyperlinkForeground" Color="#D4A84B"/>
    <SolidColorBrush x:Key="DisabledForeground" Color="#7A6A5A"/>
    <SolidColorBrush x:Key="GroupBoxBorder" Color="#6B4F2E"/>
    <SolidColorBrush x:Key="StatusGreen" Color="#8BC34A"/>
    <SolidColorBrush x:Key="StatusRed" Color="#EF5350"/>
    <SolidColorBrush x:Key="StatusBlue" Color="#64B5F6"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1A120B"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E8C97E"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2A1F14"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E8C97E"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#6B4F2E"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFE4A0"/>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
    </Style>
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
    </Style>
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
    </Style>
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
    </Style>
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
    </Style>
    <Style TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{DynamicResource WindowForeground}"/>
    </Style>
    <Style TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="{DynamicResource WindowForeground}"/>
    </Style>
    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
    </Style>
</ResourceDictionary>
