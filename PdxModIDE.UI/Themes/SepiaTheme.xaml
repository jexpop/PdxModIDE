<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="#F5E6C8"/>
    <SolidColorBrush x:Key="WindowForeground" Color="#3E2723"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#E8D5B0"/>
    <SolidColorBrush x:Key="ControlForeground" Color="#3E2723"/>
    <SolidColorBrush x:Key="ControlBorder" Color="#BCAAA4"/>
    <SolidColorBrush x:Key="AccentColor" Color="#8D6E63"/>
    <SolidColorBrush x:Key="AccentForeground" Color="#F5E6C8"/>
    <SolidColorBrush x:Key="SelectionBackground" Color="#A1887F"/>
    <SolidColorBrush x:Key="SelectionForeground" Color="#F5E6C8"/>
    <SolidColorBrush x:Key="ButtonBackground" Color="#D7C3A0"/>
    <SolidColorBrush x:Key="ButtonForeground" Color="#3E2723"/>
    <SolidColorBrush x:Key="ButtonHoverBackground" Color="#C4B08E"/>
    <SolidColorBrush x:Key="TextBoxBackground" Color="#F5E6C8"/>
    <SolidColorBrush x:Key="TextBoxForeground" Color="#3E2723"/>
    <SolidColorBrush x:Key="ListViewBackground" Color="#F5E6C8"/>
    <SolidColorBrush x:Key="ListViewForeground" Color="#3E2723"/>
    <SolidColorBrush x:Key="TreeViewBackground" Color="#F5E6C8"/>
    <SolidColorBrush x:Key="TreeViewForeground" Color="#3E2723"/>
    <SolidColorBrush x:Key="TabHeaderBackground" Color="#E8D5B0"/>
    <SolidColorBrush x:Key="TabHeaderForeground" Color="#6D4C41"/>
    <SolidColorBrush x:Key="TabSelectedBackground" Color="#F5E6C8"/>
    <SolidColorBrush x:Key="RichTextBoxBackground" Color="#F5E6C8"/>
    <SolidColorBrush x:Key="RichTextBoxForeground" Color="#3E2723"/>
    <SolidColorBrush x:Key="DiffAddedBackground" Color="#C8E6C9"/>
    <SolidColorBrush x:Key="DiffRemovedBackground" Color="#FFCDD2"/>
    <SolidColorBrush x:Key="HyperlinkForeground" Color="#6D4C41"/>
    <SolidColorBrush x:Key="DisabledForeground" Color="#8D7B70"/>
    <SolidColorBrush x:Key="GroupBoxBorder" Color="#BCAAA4"/>
    <SolidColorBrush x:Key="StatusGreen" Color="#2E7D32"/>
    <SolidColorBrush x:Key="StatusRed" Color="#C62828"/>
    <SolidColorBrush x:Key="StatusBlue" Color="#1565C0"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#F5E6C8"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#3E2723"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#E8D5B0"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#3E2723"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#A1887F"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F5E6C8"/>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
    </Style>
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
    </Style>
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
    </Style>
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
    </Style>
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
    </Style>
    <Style TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{DynamicResource WindowForeground}"/>
    </Style>
    <Style TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="{DynamicResource WindowForeground}"/>
    </Style>
    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
    </Style>
</ResourceDictionary>
