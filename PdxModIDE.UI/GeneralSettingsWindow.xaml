<Window x:Class="PdxModIDE.UI.GeneralSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="{DynamicResource Settings_Title}"
        Height="480" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="{DynamicResource Settings_Title}"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource WindowForeground}"/>
            <TextBlock Text="{DynamicResource Settings_Subtitle}"
                       TextWrapping="Wrap" Margin="0,4,0,0"
                       Foreground="{DynamicResource DisabledForeground}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="{DynamicResource Settings_LanguageSection}"
                       FontWeight="SemiBold" Margin="0,0,0,5"
                       Foreground="{DynamicResource WindowForeground}"/>
            <RadioButton x:Name="RadioLangEs" GroupName="Language" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Language_Spanish}"
                         Foreground="{DynamicResource WindowForeground}"
                         Checked="LanguageChanged"/>
            <RadioButton x:Name="RadioLangCa" GroupName="Language" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Language_Catalan}"
                         Foreground="{DynamicResource WindowForeground}"
                         Checked="LanguageChanged"/>
            <RadioButton x:Name="RadioLangEn" GroupName="Language" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Language_English}"
                         Foreground="{DynamicResource WindowForeground}"
                         Checked="LanguageChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="{DynamicResource Settings_ThemeSection}"
                       FontWeight="SemiBold" Margin="0,0,0,5"
                       Foreground="{DynamicResource WindowForeground}"/>
            <RadioButton x:Name="RadioLight" GroupName="Theme" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Theme_Light}"
                         Foreground="{DynamicResource WindowForeground}"/>
            <RadioButton x:Name="RadioDark" GroupName="Theme" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Theme_Dark}"
                         Foreground="{DynamicResource WindowForeground}"/>
            <RadioButton x:Name="RadioCk3" GroupName="Theme" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Theme_CK3}"
                         Foreground="{DynamicResource WindowForeground}"/>
            <RadioButton x:Name="RadioSepia" GroupName="Theme" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Theme_Sepia}"
                         Foreground="{DynamicResource WindowForeground}"/>
            <RadioButton x:Name="RadioContrast" GroupName="Theme" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Theme_Contrast}"
                         Foreground="{DynamicResource WindowForeground}"/>
            <RadioButton x:Name="RadioVscodeDark" GroupName="Theme" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Theme_VSCodeDark}"
                         Foreground="{DynamicResource WindowForeground}"/>
            <RadioButton x:Name="RadioVscodeLight" GroupName="Theme" Margin="0,0,0,3"
                         Content="{DynamicResource Settings_Theme_VSCodeLight}"
                         Foreground="{DynamicResource WindowForeground}"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnApply" Content="{DynamicResource Settings_ApplyButton}"
                    Width="90" Margin="0,0,8,0" Click="BtnApply_Click"/>
            <Button x:Name="BtnClose" Content="{DynamicResource Settings_CloseButton}"
                    Width="90" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
