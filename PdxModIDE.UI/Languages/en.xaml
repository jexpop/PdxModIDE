<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!--
        Language dictionary: English (en)
        Phase 1: Only used in GeneralSettingsWindow as a proof of concept
        for the hot-swap language mechanism (DynamicResource).
        The rest of the UI will be translated in later phases.
    -->

    <system:String x:Key="Settings_Title">General Settings</system:String>
    <system:String x:Key="Settings_Subtitle">These settings affect the whole application, not a specific mod.</system:String>
    <system:String x:Key="Settings_ThemeSection">Visual theme</system:String>
    <system:String x:Key="Settings_LanguageSection">Language</system:String>
    <system:String x:Key="Settings_Theme_Light">Light</system:String>
    <system:String x:Key="Settings_Theme_Dark">Dark</system:String>
    <system:String x:Key="Settings_Theme_CK3">CK3 (game colors)</system:String>
    <system:String x:Key="Settings_Theme_Sepia">Sepia (extended reading)</system:String>
    <system:String x:Key="Settings_Theme_Contrast">High contrast</system:String>
    <system:String x:Key="Settings_Theme_VSCodeDark">VS Code (dark)</system:String>
    <system:String x:Key="Settings_Theme_VSCodeLight">VS Code (light)</system:String>
    <system:String x:Key="Settings_Language_Spanish">Español</system:String>
    <system:String x:Key="Settings_Language_English">English</system:String>
    <system:String x:Key="Settings_ApplyButton">Apply</system:String>
    <system:String x:Key="Settings_CloseButton">Close</system:String>
    <system:String x:Key="Settings_AppliedMessage">Settings applied successfully.</system:String>
    <system:String x:Key="Settings_AppliedTitle">Done</system:String>

</ResourceDictionary>
