<UserControl x:Class="PdxModIDE.UI.HistoryTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="5" VerticalAlignment="Top" x:Name="InfoPlaceholder" Visibility="Visible">
            <GroupBox Header="{DynamicResource HistoryTab_Navigation}" Margin="0,0,0,5">
                <TextBlock Text="{DynamicResource HistoryTab_Navigation_Text}" TextWrapping="Wrap" Margin="5"/>
            </GroupBox>
            <GroupBox Header="{DynamicResource HistoryTab_Selection}" Margin="0,0,0,5">
                <TextBlock Text="{DynamicResource HistoryTab_Selection_Text}" TextWrapping="Wrap" Margin="5"/>
            </GroupBox>
            <GroupBox Header="{DynamicResource HistoryTab_Layers}" Margin="0,0,0,5">
                <TextBlock Text="{DynamicResource HistoryTab_Layers_Text}" TextWrapping="Wrap" Margin="5"/>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Column="0" Margin="5" VerticalAlignment="Top" x:Name="InfoPanel" Visibility="Collapsed">
            <GroupBox Margin="0,0,0,5">
                <GroupBox.Header>
                    <TextBlock Text="{DynamicResource HistoryTab_Province}" FontWeight="Bold" FontSize="14" />
                </GroupBox.Header>
                <StackPanel>
                    <Label Content="{DynamicResource HistoryTab_IDLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextIdValue" Margin="15,0,0,5" />
                    <Label Content="{DynamicResource HistoryTab_NameLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextNameValue" Margin="15,0,0,5" TextWrapping="Wrap" />
                    <Label Content="{DynamicResource HistoryTab_ColorLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextColorValue" Margin="15,0,0,5" />
                    <Label Content="{DynamicResource HistoryTab_TypeLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextTypeValue" Margin="15,0,0,5" />
                </StackPanel>
            </GroupBox>
            <GroupBox Margin="0,0,0,5" x:Name="TitleGroup">
                <GroupBox.Header>
                    <TextBlock Text="{DynamicResource HistoryTab_Title}" FontWeight="Bold" FontSize="14" />
                </GroupBox.Header>
                <StackPanel>
                    <Label x:Name="TextHolderLabel" Content="{DynamicResource HistoryTab_HolderLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextHolderValue" Margin="15,0,0,5" TextWrapping="Wrap" />
                    <Label x:Name="TextBaronyLabel" Content="{DynamicResource HistoryTab_BaronyLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextBaronyValue" Margin="15,0,0,5" />
                    <Label x:Name="TextCountyLabel" Content="{DynamicResource HistoryTab_CountyLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextCountyValue" Margin="15,0,0,5" />
                    <Label x:Name="TextDuchyLabel" Content="{DynamicResource HistoryTab_DuchyLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextDuchyValue" Margin="15,0,0,5" />
                    <Label x:Name="TextKingdomLabel" Content="{DynamicResource HistoryTab_KingdomLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextKingdomValue" Margin="15,0,0,5" />
                    <Label x:Name="TextEmpireLabel" Content="{DynamicResource HistoryTab_EmpireLabel}" FontWeight="Bold" />
                    <TextBlock x:Name="TextEmpireValue" Margin="15,0,0,5" />
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Grid Grid.Column="1" Margin="5,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                <Button Content="{DynamicResource HistoryTab_ZoomIn}" Width="70" Height="26" Click="ZoomIn_Click"/>
                <Button Content="{DynamicResource HistoryTab_ZoomOut}" Width="70" Height="26" Margin="5,0,0,0" Click="ZoomOut_Click"/>
                <Button Content="{DynamicResource HistoryTab_Fit}" Width="70" Height="26" Margin="5,0,0,0" Click="FitToWindow_Click"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,2"/>
                <Label Content="{DynamicResource HistoryTab_Year}" VerticalAlignment="Center" Margin="5,0,3,0"/>
                <TextBox x:Name="YearBox" Width="60" Height="26" VerticalContentAlignment="Center" Text="1200" TextChanged="YearBox_TextChanged"/>
                <Label x:Name="OffsetLabel" Content="{DynamicResource HistoryTab_OffsetMod}" VerticalAlignment="Center" Margin="10,0,0,0" ToolTip="{DynamicResource HistoryTab_OffsetModTooltip}"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,2"/>
                <CheckBox x:Name="BaseSourceCheck" Content="{DynamicResource HistoryTab_Base}" VerticalAlignment="Center"
                          Margin="5,0,0,0" Checked="SourceModeChanged" Unchecked="SourceModeChanged" ToolTip="{DynamicResource HistoryTab_BaseTooltip}"/>
                <CheckBox x:Name="ModSourceCheck" Content="{DynamicResource HistoryTab_Mod}" VerticalAlignment="Center"
                          Margin="5,0,0,0" Checked="SourceModeChanged" Unchecked="SourceModeChanged" ToolTip="{DynamicResource HistoryTab_ModTooltip}"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,2"/>
                <StackPanel x:Name="TitleModePanel" Orientation="Horizontal" Visibility="Collapsed">
                    <CheckBox x:Name="HolderModeCheck" Content="{DynamicResource HistoryTab_HolderMode}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="HolderModeChanged" Unchecked="HolderModeChanged" ToolTip="{DynamicResource HistoryTab_HolderModeTooltip}"/>
                    <CheckBox x:Name="CountyModeCheck" Content="{DynamicResource HistoryTab_CountyMode}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="CountyModeChanged" Unchecked="CountyModeChanged" ToolTip="{DynamicResource HistoryTab_CountyModeTooltip}"/>
                    <CheckBox x:Name="DuchyModeCheck" Content="{DynamicResource HistoryTab_DuchyMode}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="DuchyModeChanged" Unchecked="DuchyModeChanged" ToolTip="{DynamicResource HistoryTab_DuchyModeTooltip}"/>
                    <CheckBox x:Name="KingdomModeCheck" Content="{DynamicResource HistoryTab_KingdomMode}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="KingdomModeChanged" Unchecked="KingdomModeChanged" ToolTip="{DynamicResource HistoryTab_KingdomModeTooltip}"/>
                    <CheckBox x:Name="EmpireModeCheck" Content="{DynamicResource HistoryTab_EmpireMode}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="EmpireModeChanged" Unchecked="EmpireModeChanged" ToolTip="{DynamicResource HistoryTab_EmpireModeTooltip}"/>
                    <CheckBox x:Name="ShowNamesCheck" Content="{DynamicResource HistoryTab_ShowNames}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="ShowNamesChanged" Unchecked="ShowNamesChanged"/>
                </StackPanel>
                <Button x:Name="ModeToggleButton" Content="{DynamicResource HistoryTab_ModeView}" Width="100" Height="26"
                        Margin="10,0,0,0" Click="ModeToggleButton_Click"
                        ToolTip="{DynamicResource HistoryTab_ModeViewTooltip}"/>
            </WrapPanel>

            <Image x:Name="MapImage" Grid.Row="1"
                   MouseDown="MapImage_MouseDown"
                   MouseMove="MapImage_MouseMove"
                   MouseUp="MapImage_MouseUp"
                   MouseRightButtonUp="MapImage_MouseUp"
                   MouseLeave="MapImage_MouseLeave"
                   MouseWheel="MapImage_MouseWheel"
                   ContextMenu="{x:Null}"
                   Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   RenderOptions.BitmapScalingMode="Fant"/>
        </Grid>
    </Grid>
</UserControl>
