<UserControl x:Class="PdxModIDE.UI.HistoryTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="5" VerticalAlignment="Top">
            <GroupBox Header="{DynamicResource HistoryTab_Province}" Margin="0,0,0,5">
                <StackPanel>
                    <Label Content="{DynamicResource HistoryTab_ID}" x:Name="LabelId"/>
                    <Label Content="{DynamicResource HistoryTab_Name}" x:Name="LabelName"/>
                    <Label Content="{DynamicResource HistoryTab_Color}" x:Name="LabelColor"/>
                    <Label Content="{DynamicResource HistoryTab_Type}" x:Name="LabelType"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="{DynamicResource HistoryTab_Title}" Margin="0,0,0,5">
                <StackPanel>
                    <Label Content="{DynamicResource HistoryTab_Barony}" x:Name="LabelBarony"/>
                    <Label Content="{DynamicResource HistoryTab_County}" x:Name="LabelCounty"/>
                    <Label Content="{DynamicResource HistoryTab_Holder}" x:Name="LabelHolder"/>
                    <Label Content="{DynamicResource HistoryTab_Liege}" x:Name="LabelLiege"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Grid Grid.Column="1" Margin="5,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                <Button Content="{DynamicResource HistoryTab_ZoomIn}" Width="70" Height="26" Click="ZoomIn_Click"/>
                <Button Content="{DynamicResource HistoryTab_ZoomOut}" Width="70" Height="26" Margin="5,0,0,0" Click="ZoomOut_Click"/>
                <Button Content="{DynamicResource HistoryTab_Fit}" Width="70" Height="26" Margin="5,0,0,0" Click="FitToWindow_Click"/>
                <Label Content="{DynamicResource HistoryTab_Year}" VerticalAlignment="Center" Margin="10,0,3,0"/>
                <TextBox x:Name="YearBox" Width="60" Height="26" VerticalContentAlignment="Center" Text="1200" TextChanged="YearBox_TextChanged"/>
                <Label x:Name="OffsetLabel" Content="{DynamicResource HistoryTab_OffsetMod}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray" ToolTip="{DynamicResource HistoryTab_OffsetModTooltip}"/>
                <CheckBox x:Name="BaseSourceCheck" Content="{DynamicResource HistoryTab_Base}" VerticalAlignment="Center"
                          Margin="10,0,0,0" Checked="SourceModeChanged" Unchecked="SourceModeChanged" ToolTip="{DynamicResource HistoryTab_BaseTooltip}"/>
                <CheckBox x:Name="ModSourceCheck" Content="{DynamicResource HistoryTab_Mod}" VerticalAlignment="Center"
                          Margin="5,0,0,0" Checked="SourceModeChanged" Unchecked="SourceModeChanged" ToolTip="{DynamicResource HistoryTab_ModTooltip}"/>
                <StackPanel x:Name="TitleModePanel" Orientation="Horizontal" Visibility="Collapsed">
                    <CheckBox x:Name="HolderModeCheck" Content="{DynamicResource HistoryTab_HolderMode}" VerticalAlignment="Center"
                              Margin="10,0,0,0" Checked="HolderModeChanged" Unchecked="HolderModeChanged" ToolTip="{DynamicResource HistoryTab_HolderModeTooltip}"/>
                    <CheckBox x:Name="CountyModeCheck" Content="{DynamicResource HistoryTab_CountyMode}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="CountyModeChanged" Unchecked="CountyModeChanged" ToolTip="{DynamicResource HistoryTab_CountyModeTooltip}"/>
                    <CheckBox x:Name="DuchyModeCheck" Content="{DynamicResource HistoryTab_DuchyMode}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="DuchyModeChanged" Unchecked="DuchyModeChanged" ToolTip="{DynamicResource HistoryTab_DuchyModeTooltip}"/>
                    <CheckBox x:Name="KingdomModeCheck" Content="{DynamicResource HistoryTab_KingdomMode}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="KingdomModeChanged" Unchecked="KingdomModeChanged" ToolTip="{DynamicResource HistoryTab_KingdomModeTooltip}"/>
                    <CheckBox x:Name="EmpireModeCheck" Content="{DynamicResource HistoryTab_EmpireMode}" VerticalAlignment="Center"
                              Margin="5,0,0,0" Checked="EmpireModeChanged" Unchecked="EmpireModeChanged" ToolTip="{DynamicResource HistoryTab_EmpireModeTooltip}"/>
                </StackPanel>
                <Label x:Name="StatusLabel" Content="{DynamicResource HistoryTab_Ready}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray"/>
            </StackPanel>

            <Image x:Name="MapImage" Grid.Row="1"
                   MouseDown="MapImage_MouseDown"
                   MouseMove="MapImage_MouseMove"
                   MouseUp="MapImage_MouseUp"
                   MouseRightButtonUp="MapImage_MouseUp"
                   MouseLeave="MapImage_MouseLeave"
                   MouseWheel="MapImage_MouseWheel"
                   ContextMenu="{x:Null}"
                   Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   RenderOptions.BitmapScalingMode="Fant"/>
        </Grid>
    </Grid>
</UserControl>
