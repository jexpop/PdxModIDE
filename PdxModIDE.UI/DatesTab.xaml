<UserControl x:Class="PdxModIDE.UI.DatesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <GroupBox Header="{DynamicResource DatesTab_YearOffset}">
                <TextBox Text="{Binding YearOffset, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"/>
            </GroupBox>

            <GroupBox Header="{DynamicResource DatesTab_EndDate}" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource DatesTab_EndDateLabel}"/>
                    <TextBox x:Name="EndDateTextBox" Margin="0,5,0,5"/>
                    <TextBlock x:Name="EndDateSourceText" Foreground="Gray" Margin="0,0,0,10"/>
                    <Button Content="{DynamicResource DatesTab_SaveEndDate}" Width="200" HorizontalAlignment="Left"
                            Click="SaveEndDate_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource DatesTab_ModulesToProcess}" Margin="0,10,0,0">
                <StackPanel>
                    <ScrollViewer x:Name="ModulesScroll" MaxHeight="300" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Modules}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsActive, Mode=TwoWay}" 
                                              Margin="4,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Content="{DynamicResource DatesTab_Process}" Width="100" HorizontalAlignment="Left" Margin="0,10,0,0"
                            Click="Process_Click"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
